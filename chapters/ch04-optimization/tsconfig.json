{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "ES2020"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@catalog/*": ["./src/catalog/*"],
      "@analytics/*": ["./src/analytics/*"],
      "@ui/*": ["./src/ui/*"]
    },
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["src"]
}